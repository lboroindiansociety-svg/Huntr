VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Logo.dev publishable key (safe for browser — used in img.logo.dev URLs)
VITE_LOGO_DEV_PUBLISHABLE_KEY=live_your_publishable_key

# Logo.dev secret key — local dev only (Vite proxy). Never commit real values.
LOGO_DEV_SECRET_KEY=sk_your_secret_key

# Logo.dev secret key for production — set in Supabase Edge Function secrets:
# supabase secrets set LOGO_DEV_SECRET_KEY=sk_your_secret_key

# Gemini API key — local dev only (Vite middleware for job URL auto-fill). Never commit real values.
# Uses gemini-2.5-flash-lite (cheapest model). Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Gemini API key for production — set in Supabase Edge Function secrets:
# supabase secrets set GEMINI_API_KEY=your_gemini_api_key
# Then deploy: supabase functions deploy parse-job-url

# Supabase service role key — local dev only (Trackr sync middleware). Never commit real values.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Adzuna job search — register at https://developer.adzuna.com/signup
# ADZUNA_APP_ID=your_app_id
# ADZUNA_APP_KEY=your_app_key
# Production: supabase secrets set ADZUNA_APP_ID=... ADZUNA_APP_KEY=...

# Reed job search — register at https://www.reed.co.uk/developers
# REED_API_KEY=your_reed_api_key
# Production: supabase secrets set REED_API_KEY=...

# Optional Jina Reader API key — higher rate limits for blocked sites like Revolut.
# Works without a key for local dev. Get one at https://jina.ai/reader
# JINA_API_KEY=jina_your_key
